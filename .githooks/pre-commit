#!/usr/bin/env bash
set -euo pipefail

# Auto-format before checks (matches `make fmt` without ensure-hooks)
make fmt-core

# Stage any formatting changes so they are included in the commit
if ! git diff --quiet; then
  echo "Formatting changed files; staging tracked updates..."
  git add -u
fi

# Reject accidentally staged large files before running slower checks.
large_file_limit_bytes=$((20 * 1024 * 1024))
large_files=()
while IFS= read -r -d '' path; do
  if [ ! -f "$path" ]; then
    continue
  fi

  size="$(wc -c <"$path" | tr -d ' ')"
  if [ "$size" -gt "$large_file_limit_bytes" ]; then
    large_files+=("$path (${size} bytes)")
  fi
done < <(git diff --cached --name-only -z --diff-filter=ACMR)

if [ "${#large_files[@]}" -gt 0 ]; then
  echo "Large staged files detected (>20 MiB):"
  printf '  %s\n' "${large_files[@]}"
  echo "Remove them from the commit or use an external artifact store."
  exit 1
fi

# Run checks
make fmt-check-core

echo "Pre-commit checks passed."
